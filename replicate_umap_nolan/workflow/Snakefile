WINDOW_SIZES = [75]
WINDOW_STEP_SIZES = [5]

wildcard_constraints:
    window_size=r"\d+",
    window_step_size=r"\d+"

rule all_window_sets:
    input:
        expand(
            "results/{window_size}/{window_step_size}/output.pdf",
            window_size=WINDOW_SIZES,
            window_step_size=WINDOW_STEP_SIZES
        )

rule window_set:
    input:
        script="workflow/scripts/run.py"
    output:
        "results/{window_size}/{window_step_size}/output.pdf"
    threads: 32
    resources:
        nodes=1,
        mem_str="1gb",
        runtime=14400
    shell:
        "OMP_NUM_THREADS={threads} workflow/envs/venv/bin/python {input.script} --window-size {wildcards.window_size} --window-step-size {wildcards.window_step_size}"

rule all_broken_window_sets:
    input:
        expand(
            "results/broken/{window_size}/{window_step_size}/output.pdf",
            window_size=WINDOW_SIZES,
            window_step_size=WINDOW_STEP_SIZES
        )

rule broken_window_set_umap:
    input:
        script="workflow/scripts/make_umap.py",
        fv="temp/{window_size}/{window_step_size}/feature_vecs.npy"
    output:
        "results/broken/{window_size}/{window_step_size}/output.pdf"
    threads: 16
    resources:
        nodes=1,
        mem_str="200gb",
        runtime=14400
    shell:
        "OMP_NUM_THREADS={threads} workflow/envs/venv/bin/python {input.script} --window-size {wildcards.window_size} --window-step-size {wildcards.window_step_size} --feature-vecs-path {input.fv} --output-file {output}"

rule broken_window_set_fv:
    input:
        script="workflow/scripts/make_feature_vecs.py"
    output:
        protected("temp/{window_size}/{window_step_size}/feature_vecs.npy")
    threads: 32
    resources:
        nodes=1,
        mem_str="1gb",
        runtime=14400
    shell:
        "OMP_NUM_THREADS={threads} workflow/envs/venv/bin/python {input.script} --window-size {wildcards.window_size} --window-step-size {wildcards.window_step_size} --output-file {output}"
